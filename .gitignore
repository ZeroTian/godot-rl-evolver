# Python venv / 构建产物(放仓库外,如 ~/.local/share/godot-rl-venv)
venv/
.venv/
.testvenv/
__pycache__/
*.pyc

# 训练产物 / 模型 / 录像 / 日志(不入库)
*.zip
*.onnx
rec/
*.gif
*.log
game_dbg.log
# PNG 只排除根级和 harness 下的截图/产物；testbed grey-box 资源通过下方白名单放行
*.png
!testbed_platformer/assets/grey_box/*.png

# 优化闭环运行产物（telemetry/report/memory/模型，不入库）
.artifacts/

# testbed Godot 导入缓存（不入库）
testbed_platformer/.godot/
testbed_platformer/.import/

# telemetry 运行产物(不入库)
telemetry/
report.json

# Godot 导入缓存
.godot/
.import/

# OMC 工作目录(不入库)
.omc/

# 私密/凭证(永不提交)
.env
*cookies*.txt
*.key
*secret*
